{
  "name": "hackgraph",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "homepage": "https://hackgraph.github.io/",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsx scripts/gen-reference.ts",
    "gen:reference": "tsx scripts/gen-reference.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:refs": "node scripts/check-refs.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@xyflow/react": "^12.3.5",
    "fflate": "^0.8.3",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "$vite"
    },
    "esbuild": "^0.25.0",
    "form-data": "^4.0.6"
  }
}
